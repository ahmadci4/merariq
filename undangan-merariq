<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="page-title">Loading Undangan...</title>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Elemen Style Dinamis (Tema Warna akan diinjeksi lewat JS) -->
    <style id="dynamic-theme">
        :root {
            --color-primary: #C5A059; /* Default Gold */
            --color-bg: #FAF7F2;      /* Default Cream */
        }
        body { background-color: var(--color-bg); }
        .text-primary { color: var(--color-primary); }
        .bg-primary { background-color: var(--color-primary); }
    </style>
</head>
<body class="antialiased text-gray-800 flex flex-col items-center justify-center min-h-screen">

    <!-- Loading Screen (Tampil sebelum data selesai ditarik) -->
    <div id="loading" class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-gray-900 mb-4"></div>
        <p>Menyiapkan Undangan...</p>
    </div>

    <!-- Konten Undangan (Kosong, akan diisi oleh JavaScript) -->
    <main id="app-content" class="hidden text-center max-w-md p-8 bg-white shadow-2xl rounded-2xl border-t-8 border-primary">
        <p class="text-sm tracking-widest text-gray-500 mb-2 uppercase">The Wedding Of</p>
        
        <!-- ID ini adalah target yang akan diganti teksnya -->
        <h1 id="nama-pengantin" class="text-5xl font-serif text-primary mb-4 font-bold">Nama & Nama</h1>
        
        <p class="italic text-gray-600 mb-6">Kami mengundang Anda pada hari bahagia kami:</p>
        
        <div class="bg-gray-50 p-4 rounded-lg mb-6">
            <h3 id="tanggal-acara" class="font-bold text-lg">Tanggal Acara</h3>
            <p id="lokasi-acara" class="text-sm text-gray-600">Lokasi Acara</p>
        </div>

        <!-- Gambar Utama -->
        <img id="foto-utama" src="" alt="Foto Pasangan" class="w-full h-64 object-cover rounded-xl mb-6 shadow-md">

        <!-- Audio Player Dinamis -->
        <audio id="musik-latar" controls class="w-full h-10"></audio>
    </main>

    <script>
        // 1. MENDAPATKAN ID DARI URL (contoh: web.com/?id=budi-siti)
        const urlParams = new URLSearchParams(window.location.search);
        // Jika tidak ada ID di URL, pakai 'default'
        const clientId = urlParams.get('id') || 'default';

        // 2. URL API DARI SHEETDB.IO
        // TODO: GANTI URL DI BAWAH INI DENGAN API URL MILIK ANDA DARI LANGKAH 3
        const SHEETDB_API_URL = 'https://sheetdb.io/api/v1/gqsl1mcjjkx7t';

        // 3. FUNGSI UNTUK MERENDER HALAMAN
        function renderUndangan(data) {
            // Mengganti Teks
            document.getElementById('page-title').innerText = `Undangan: ${data.namaPria} & ${data.namaWanita}`;
            document.getElementById('nama-pengantin').innerText = `${data.namaPria} & ${data.namaWanita}`;
            document.getElementById('tanggal-acara').innerText = data.tanggal;
            document.getElementById('lokasi-acara').innerText = data.lokasi;
            
            // Mengganti Foto dan Musik
            document.getElementById('foto-utama').src = data.fotoUrl;
            document.getElementById('musik-latar').src = data.musikUrl;

            // MENGUBAH TEMA WARNA SECARA DINAMIS SESUAI PILIHAN PELANGGAN
            const rootStyle = `
                :root {
                    --color-primary: ${data.temaWarna};
                    --color-bg: ${data.temaBg};
                }
            `;
            document.getElementById('dynamic-theme').innerHTML += rootStyle;

            // Hilangkan Loading, Tampilkan Konten
            document.getElementById('loading').style.display = 'none';
            document.getElementById('app-content').classList.remove('hidden');
        }

        // 4. MENGAMBIL DATA DARI GOOGLE SHEETS VIA API
        async function fetchUndanganData() {
            try {
                // Mencari data spesifik berdasarkan kolom 'id_pelanggan' di Google Sheets
                const response = await fetch(`${SHEETDB_API_URL}/search?id_pelanggan=${clientId}`);
                const data = await response.json();

                // Jika data ditemukan
                if (data && data.length > 0) {
                    renderUndangan(data[0]); // Render baris pertama yang cocok
                } else {
                    // Jika ID tidak ada di Excel
                    document.getElementById('loading').innerHTML = '<p class="text-red-500 font-bold">Maaf, Data undangan tidak ditemukan!</p>';
                }
            } catch (error) {
                console.error('Error fetching data:', error);
                document.getElementById('loading').innerHTML = '<p class="text-red-500 font-bold">Terjadi kesalahan sistem saat mengambil data.</p>';
            }
        }

        // 5. EKSEKUSI PENGAMBILAN DATA
        if (clientId !== 'default') {
            fetchUndanganData();
        } else {
            // Jika web dibuka tanpa link khusus, tampilkan pesan ini
            document.getElementById('loading').innerHTML = `
                <div class="text-center p-6">
                    <h2 class="text-xl font-bold mb-2">Selamat Datang di Bisnis Undangan</h2>
                    <p class="text-gray-600">URL tidak lengkap. Silakan tambahkan ID Pelanggan di link.<br><br>Contoh: <b>namawebsite.com/?id=romeo-juliet</b></p>
                </div>
            `;
        }
    </script>
</body>
</html>
